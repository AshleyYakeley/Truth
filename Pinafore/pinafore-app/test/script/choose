#!/usr/bin/env pinafore1
import "media", "gnome"
do
{
    gtk <- runAsync.GTK;
    open.Window.GTK gtk (300, 100) ap{"Choose File"} blank.Widget.GTK;
}

{#
run.GTK $ fn gtk =>
# async.Task $ fn _ =>
let rec {
    showFile: Action Unit =
        do {
            owner <- open.Window.GTK gtk (300, 100) ap{"Choose File"} blank.Widget.GTK;
            task <- chooseExistingFile.GTK gtk owner [[["Image"]]];
            sleep $ Seconds 4;
            mfile <- wait.Task task;
            close.Window.GTK owner;
            file <- orStop mfile;
            ref <- makeRef.File.GIO file;
            media <- get ref;
            jpeg <- orStop $ decode asMedia.JPEG.Image media;
            path = file >- fn {
                Path.File.GIO path => path;
                _ => "unknown";
            };
            image = interpret jpeg;
            open.Window.GTK gtk (size.Image image) ap{path} $ image.Widget.GTK ap{image};
            showFile;
        };
} showFile
#}
